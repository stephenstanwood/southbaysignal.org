---
/**
 * Newsletter subscription tracker — private admin view.
 *
 * Auth: ?key=<ADMIN_KEY> query param. Set ADMIN_KEY in Vercel env.
 * No session — refresh with the key in the URL each time. This is
 * intentionally simple; the page is read-only and not linked from anywhere.
 */
import { readTracker } from "../../lib/lookout/tracker.ts";
import type { NewsletterTarget, SubscribeStatus } from "../../lib/lookout/tracker.ts";

export const prerender = false;

const providedKey = Astro.url.searchParams.get("key") ?? "";
const expectedKey = process.env.ADMIN_KEY ?? import.meta.env.ADMIN_KEY ?? "";

let authed = false;
let doc: Awaited<ReturnType<typeof readTracker>> | null = null;
let loadError: string | null = null;

if (expectedKey && providedKey === expectedKey) {
  authed = true;
  try {
    doc = await readTracker();
  } catch (err) {
    loadError = (err as Error).message;
  }
}

function statusLabel(s: SubscribeStatus): string {
  switch (s) {
    case "not-attempted": return "not attempted";
    case "signup-posted": return "signed up — awaiting email";
    case "confirmed": return "confirmed";
    case "receiving": return "receiving ✅";
    case "failed": return "failed";
    case "needs-manual": return "needs manual click";
    case "blocked": return "blocked";
  }
}

function statusColor(s: SubscribeStatus): string {
  switch (s) {
    case "receiving": return "#16a34a";
    case "confirmed": return "#2563eb";
    case "signup-posted": return "#6366f1";
    case "not-attempted": return "#6b7280";
    case "needs-manual": return "#d97706";
    case "failed": return "#dc2626";
    case "blocked": return "#7c2d12";
  }
}

function relativeTime(iso: string | undefined): string {
  if (!iso) return "—";
  const then = new Date(iso).getTime();
  const diff = Date.now() - then;
  if (diff < 60_000) return "just now";
  if (diff < 3600_000) return `${Math.floor(diff / 60_000)}m ago`;
  if (diff < 86400_000) return `${Math.floor(diff / 3600_000)}h ago`;
  return `${Math.floor(diff / 86400_000)}d ago`;
}

const targets = doc?.targets ?? [];
const grouped: Record<string, NewsletterTarget[]> = {};
for (const t of targets) {
  (grouped[t.category] ??= []).push(t);
}

const summary = {
  total: targets.length,
  receiving: targets.filter((t) => t.status === "receiving").length,
  signupPosted: targets.filter((t) => t.status === "signup-posted").length,
  confirmed: targets.filter((t) => t.status === "confirmed").length,
  notAttempted: targets.filter((t) => t.status === "not-attempted").length,
  needsManual: targets.filter((t) => t.status === "needs-manual").length,
  failed: targets.filter((t) => t.status === "failed").length,
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Newsletter tracker — SBT admin</title>
    <style>
      :root {
        --bg: #fafaf9;
        --fg: #1c1917;
        --muted: #78716c;
        --card: #ffffff;
        --border: #e7e5e4;
      }
      * { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--fg);
        margin: 0;
        padding: 0;
        line-height: 1.5;
      }
      .container { max-width: 1100px; margin: 0 auto; padding: 0 16px 32px; }
      h1 { font-size: 24px; margin: 0 0 4px; }
      .sub { color: var(--muted); font-size: 14px; margin-bottom: 16px; }

      /* Floating header */
      .sticky-header {
        position: sticky;
        top: 0;
        z-index: 20;
        background: rgba(250, 250, 249, 0.95);
        backdrop-filter: saturate(1.4) blur(10px);
        -webkit-backdrop-filter: saturate(1.4) blur(10px);
        border-bottom: 1px solid var(--border);
        padding: 12px 16px;
        margin-bottom: 16px;
      }
      .sticky-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        gap: 12px 16px;
        align-items: center;
      }
      .title-block { flex: 0 0 auto; }
      .title-block h1 { font-size: 18px; margin: 0; }
      .title-block .sub { font-size: 11px; color: var(--muted); margin: 0; }

      .copy-button {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 14px;
        background: #111827;
        color: white;
        border: 0;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        font-family: inherit;
        transition: background 120ms, transform 80ms;
        flex: 0 0 auto;
      }
      .copy-button:hover { background: #1f2937; }
      .copy-button:active { transform: scale(0.97); }
      .copy-button code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 12px;
        background: rgba(255,255,255,0.15);
        padding: 2px 6px;
        border-radius: 4px;
      }
      .copy-button.copied { background: #16a34a; }

      .summary {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        flex: 1 1 auto;
        justify-content: flex-end;
      }
      .stat {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 6px 10px;
        display: flex;
        gap: 6px;
        align-items: baseline;
        font-size: 12px;
      }
      .stat .num { font-size: 15px; font-weight: 600; }
      .stat .lbl { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; }
      h2 { font-size: 16px; margin: 24px 0 8px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
      table { width: 100%; border-collapse: collapse; background: var(--card); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
      th, td { text-align: left; padding: 8px 12px; font-size: 14px; border-bottom: 1px solid var(--border); vertical-align: top; }
      th { background: #f5f5f4; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); }
      tr:last-child td { border-bottom: none; }
      .name { font-weight: 500; }
      .provider { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11px; color: var(--muted); }
      .status-pill { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 11px; font-weight: 500; color: white; }
      .meta { font-size: 12px; color: var(--muted); }
      a { color: #2563eb; text-decoration: none; }
      a:hover { text-decoration: underline; }
      .unauth { max-width: 400px; margin: 80px auto; text-align: center; }
      .unauth input { padding: 8px 12px; border: 1px solid var(--border); border-radius: 6px; width: 100%; font-size: 14px; }
      .unauth button { margin-top: 8px; padding: 8px 16px; background: #2563eb; color: white; border: 0; border-radius: 6px; font-size: 14px; cursor: pointer; }
      .delete-btn { background: transparent; border: 1px solid var(--border); color: #b91c1c; border-radius: 4px; font-size: 11px; padding: 3px 8px; cursor: pointer; font-family: inherit; }
      .delete-btn:hover { background: #fef2f2; border-color: #fca5a5; }
      .delete-btn:disabled { opacity: 0.5; cursor: wait; }
    </style>
  </head>
  <body>
    {authed && !loadError && (
      <header class="sticky-header">
        <div class="sticky-inner">
          <div class="title-block">
            <h1>Newsletter tracker</h1>
            <p class="sub">{targets.length} targets • updated {doc && relativeTime(doc.updatedAt)}</p>
          </div>
          <button class="copy-button" id="copyEmailBtn" type="button">
            📋 Copy <code>sandcathype@gmail.com</code>
          </button>
          <div class="summary">
            <div class="stat"><span class="num">{summary.receiving}</span><span class="lbl">receiving</span></div>
            <div class="stat"><span class="num">{summary.signupPosted}</span><span class="lbl">awaiting</span></div>
            <div class="stat"><span class="num">{summary.confirmed}</span><span class="lbl">confirmed</span></div>
            <div class="stat"><span class="num">{summary.notAttempted}</span><span class="lbl">new</span></div>
            <div class="stat"><span class="num">{summary.needsManual}</span><span class="lbl">manual</span></div>
            <div class="stat"><span class="num">{summary.failed}</span><span class="lbl">failed</span></div>
          </div>
        </div>
      </header>
    )}
    <div class="container">
      {!authed ? (
        <div class="unauth">
          <h1>Newsletter tracker</h1>
          <p class="sub">private admin view</p>
          <form method="GET">
            <input name="key" type="password" placeholder="admin key" autofocus />
            <button type="submit">View</button>
          </form>
        </div>
      ) : loadError ? (
        <div>
          <h1>Newsletter tracker</h1>
          <p class="sub">failed to load tracker: {loadError}</p>
        </div>
      ) : (
        <>
          {Object.entries(grouped).sort().map(([category, items]) => (
            <>
              <h2>{category}</h2>
              <table>
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>City</th>
                    <th>Status</th>
                    <th>Last received</th>
                    <th>Count</th>
                    <th>Attempted</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  {items.sort((a, b) => a.name.localeCompare(b.name)).map((t) => (
                    <tr data-target-id={t.id}>
                      <td>
                        <div class="name"><a href={t.signupUrl} target="_blank">{t.name}</a></div>
                        <div class="provider">{t.provider}</div>
                        {t.notes && <div class="meta">{t.notes}</div>}
                      </td>
                      <td class="meta">{t.city ?? "—"}</td>
                      <td><span class="status-pill" style={`background: ${statusColor(t.status)}`}>{statusLabel(t.status)}</span></td>
                      <td class="meta">{relativeTime(t.lastReceivedAt)}</td>
                      <td class="meta">{t.receivedCount ?? 0}</td>
                      <td class="meta">{relativeTime(t.attemptedAt)}</td>
                      <td><button class="delete-btn" data-id={t.id} data-name={t.name}>delete</button></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </>
          ))}
        </>
      )}
    </div>
    {authed && (
      <script is:inline define:vars={{ providedKey }}>
        // Copy email button
        document.getElementById("copyEmailBtn")?.addEventListener("click", async (e) => {
          const btn = e.currentTarget;
          const email = "sandcathype@gmail.com";
          try {
            await navigator.clipboard.writeText(email);
            const prev = btn.innerHTML;
            btn.classList.add("copied");
            btn.innerHTML = "✓ Copied!";
            setTimeout(() => {
              btn.classList.remove("copied");
              btn.innerHTML = prev;
            }, 1400);
          } catch (err) {
            alert("couldn't copy — " + err.message);
          }
        });

        // Delete row handler
        document.addEventListener("click", async (e) => {
          const btn = e.target.closest(".delete-btn");
          if (!btn) return;
          const id = btn.dataset.id;
          const name = btn.dataset.name || id;
          if (!confirm(`Delete "${name}"?`)) return;
          btn.disabled = true;
          btn.textContent = "deleting…";
          try {
            const res = await fetch(`/api/admin/newsletters/delete?id=${encodeURIComponent(id)}&key=${encodeURIComponent(providedKey)}`, {
              method: "DELETE",
            });
            if (!res.ok) {
              const err = await res.json().catch(() => ({}));
              alert(`delete failed: ${err.error || res.status}`);
              btn.disabled = false;
              btn.textContent = "delete";
              return;
            }
            const row = btn.closest("tr");
            if (row) row.remove();
          } catch (err) {
            alert(`delete error: ${err.message}`);
            btn.disabled = false;
            btn.textContent = "delete";
          }
        });
      </script>
    )}
  </body>
</html>
